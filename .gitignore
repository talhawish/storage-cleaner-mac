# OS Metadata
.DS_Store
Thumbs.db

# Swift / Package Manager
.build/
.swiftpm/
/Packages
/Package.resolved

# Xcode Projects
# The .xcodeproj is committed and uses filesystem-synchronized groups, so files
# on disk are added to targets automatically — no regeneration needed. Only the
# user-specific state below is ignored.

# Xcode User Data
# These should never be committed as they are user-specific
xcuserdata/
DerivedData/
*.xcuserstate
*.xccheckout
*.moved-aside

# Build Artifacts
build/
bin/
reports/
*.ipa
*.dSYM.zip
*.dSYM

# Project Specific
.commandcode/

